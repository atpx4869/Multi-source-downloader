var lineList = new Array();
$(document).ready(function(){
	// 初始化词云
    drawWordCloud();
	var config = {
			state	: '现行',
			type	: 'name'
		};
	$('.status ul li').click(function(){
		var el = $(this);
		if(el.attr('tab_id')=='2'){
			if(el.hasClass('spe2')){
				return false;
			}		
			el.siblings().removeClass('spe1');
			el.siblings().removeClass('spe2');
			el.addClass('spe2');
		}else{
			 if(el.hasClass('spe1')){
				return false;
			}		
			el.siblings().removeClass('spe1');
			el.siblings().removeClass('spe2');
			el.addClass('spe1'); 
		}
		
		config.state = el.attr('data-searchType');
	});
	//,#searchICS
	$('#searchCode,#searchName').change(function(){
		config.type = this.value;
	});
	$('#searchName').click();
	
	$('#pSearchBtn').click(function(){
		$('#form1 .form-group').each(function(){
			var cache = '';
			$(this).find('input:checked').each(function(){
				cache += ('|'+$(this).val());
			});
			$(this).find('.result').val(cache.substring(1));
		});
		$('#form1').submit();
	});
	
	$('#icsSearchBtn').on('click',function(){ 
		window.open('/bzgk/gb/icsMainQuery?icsName='+$('#icsInput').val());   
	});
	$('#openIcs').on('click',function(){
		if($('#icsDiv').is(':visible')){
			$(this).html('展开  <span class="glyphicon glyphicon-chevron-down"> </span>');
			$('#icsDiv').hide();
		} else {
			$(this).html('收起  <span class="glyphicon glyphicon-chevron-up"> </span>&nbsp;&nbsp;&nbsp;&nbsp;点击左侧黄色文件夹可展开下一级'); 
			$('#icsDiv').show();
		}
	});
	function ss() {
		var str = $.trim($(this).attr("id"));
		var name = $.trim($(this).attr("name"));
		if(str!='-1'){
			$('#icsInput').val(str);
			$("#icsInput").next().html(str+'_'+name); 
		}
		$.ajax({
					type : "post",
					url : '/bzgk/' + 'gb/ajaxIcsList', 
					data : {
						"pcode" : str
					},
					dateType : "json",
					success : function(data) { 
						if (data.length > 0) {//如果有下级
							var html = '<div class="row" style="margin-bottom: 0;">';

								for (var ii = 0; ii < data.length; ii++) {
									html += '<div class="col-md-4"><a class="btn multiSelectBtn icslist1"style="width:100%;text-align:left;padding-left:4px !important;margin-bottom:5px;">';
									if (data[ii].leaf=="0"||(data[ii].icsChilds!=null&&data[ii].icsChilds.length > 0)) {
										html += '<span class="glyphicon glyphicon-folder-open icstype" style="float:left;width:10%;color:#f8da70;" id="'
												+ data[ii].icsCode
												+ '" name="'
												+ data[ii].icsName
												+ '"></span>';
									} else {
										html += '<span class="glyphicon glyphicon-list-alt icslist" style="float:left;width:10%;color:##d8d8d8;" id="'
												+ data[ii].icsCode
												+ '" name="'
												+ data[ii].icsName
												+ '">&nbsp;</span>';
									}
									html += '<span class="icslist" style="float:left;width:80%;white-space:normal;" id="'
											+ data[ii].icsCode
											+ '" name="'
											+ data[ii].icsName
											+ '"> '
											+ data[ii].icsCode
											+ '_' 
											+ data[ii].icsName
											+ '</span><span style="float:right;margin:2px;" class="text-success glyphicon glyphicon-ok-circle hidden"></span></a></div>';
									if (ii % 3 == 2) {
										html += '</div><div class="row" style="margin-bottom: 0;">';
									}
								}

							$("#hdDiv").html(html);
							//面包屑栈操作
							var obj = new Object();
							obj.code = str;
							obj.name = name;
							if (lineList.length == 0) {
								lineList.push(obj);
							} else {
								try {
									var j = 0;
									for (; j < lineList.length; j++) {
										if (str
												.indexOf(lineList[j].code) >= 0) {
											break;
										}
									}
									if (j < lineList.length
											&& lineList[j].code == str) {
										lineList
												.splice(j,
														lineList.length
																- j + 1);
									} else {
										lineList.splice(j + 1,
												lineList.length - j);
									}

									lineList.push(obj)
								} catch (e) {
									throw e;
								}

							}
							var line = '<li><a href="#" class="icstype allType" id="-1" name="全部">全部</a></li>';
							if (str == -1) {
								lineList = new Array();
							}
							for (var i = 0; i < lineList.length; i++) {
								line = line
										+ '<li class="active icstype" id="'+lineList[i].code+'" name="'+lineList[i].name+'"><a href="#">'
										+ lineList[i].code
										+ '_'
										+ lineList[i].name + '</a></li>';
								;
							}

							$("#line").empty().append(line);
							$(".icstype").on("click", ss);
							$(".icslist").on("click", tt);

						} else {//如果没有下级

							return;
						}
					},
					error : function() {

					}

				});
	}

	function tt() {
		$(this).parent("a").toggleClass("multiSelectBtn-s");
		$(this).parent().find(".glyphicon-ok-circle").toggleClass("hidden");
		var text = '',codes = '';
		$('#icsDiv .multiSelectBtn-s').each(function(){
			var icsList = $(this).find('.icslist');
			text += ($.trim(icsList.attr("id"))+'_'+$.trim(icsList.attr("name"))+'|');
			codes += ($.trim(icsList.attr("id"))+'|');
		});
		if(text==''){
			var icsType = $('.breadcrumb .icstype:last');
			if($.trim(icsType.attr("id"))=='-1'){	
				$('#icsInput').val('');
				$("#icsInput").next().html('全部'); 
			} else{
				$('#icsInput').val($.trim(icsType.attr("id")))
				$("#icsInput").next().html($.trim(icsType.attr("id"))+'_'+$.trim(icsType.attr("name")));
			}
		} else {
			$('#icsInput').val(codes.substring(0,codes.length-1))
			$('#icsInput').next().html(text.substring(0,text.length-1));
		}
		p6 = codes.substring(0,codes.length-1);
	}
	
	//选择css分类
	$(".icstype").on("click", ss);
	$(".icslist").on("click", tt);
	$(document).on("click",".allType",function(){
		$('#icsInput').val('')
		$('#icsInput').next().html('全部');
	});
	$('#form1 .checkbox-inline input').on('change',function(){
		if($(this).parent().parent().parent().hasClass('multi')){
			if($(this).hasClass('allType')){
				$(this).parent().siblings().find('input').removeAttr('checked'); 
				$(this).prop('checked',true);
			} else{
				$(this).parent().parent().find('.allType').removeAttr('checked');
				if($(this).parent().parent().find('input').length==($(this).parent().parent().find('input:checked').length+1)){
					$(this).parent().parent().find('input').removeAttr('checked');
					$(this).parent().parent().find('.allType').prop('checked',true);
				}
			}
		} else {
			$(this).parent().siblings().find('input').removeAttr('checked'); 
		}
		if($(this).parent().parent().find('input:checked').length==0){
			$(this).parent().parent().find('.allType').prop('checked',true);
		} 
	});
	/* $("#cloudTag").windstagball({
        radius:80, 
        speed:1,
    }); */
	
	var len = $(".snews .list").length;
	var current = 0;
	var m;
	var time = 5000;
	if(len>1)
	{
		$(".snews .down").on("click",function(){
			if(current!=len-1)
			{
				current++;
				clearInterval(m);
				m = setInterval(auto,time);
				move();
			}
			return false;
		});
		$(".snews .up").on("click",function(){
			if(current!=0)
			{
				current--;
				clearInterval(m);
				m = setInterval(auto,time);
				move();
			}
			return false;
		});
		m = setInterval(auto,time);
	}
	function move()
	{
		var pos = 0 - current * 52;
		$(".snews .max").stop().animate({marginTop:pos},500);
	}
	function auto()
	{
		if(current!=len-1)
		{
			current++;
		}
		else
		{
			current = 0;
		}
		move();
	}	
	
	$(".snews .icon").on("click",function(e){
		if($(".snews").attr("class").indexOf("closed") != -1)
		{
			$(".snews").removeClass("closed");
		}
		else
		{
			$(".snews").addClass("closed");
		}
	});
});

function adquery(){
	window.open('adindex','_self');
}
function icsquery(){
	window.open('icstreeindex','_self');
}
function search(key){
	window.open('/bzgk/gb/icsMainQuery?icsName='+key); 
}
function searchN(id){
	window.open("/bzgk/gb/nd?no="+id,"_blank"); 
}
</script>
