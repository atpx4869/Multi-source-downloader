<script type="text/javascript">
//示例数据（包含文本、字号和链接）
const words = [
    { text: "消防", size: 40 },
    { text: "建筑设计防火规范", size: 18 },
    { text: "食品", size: 25 },
    { text: "安全", size: 14 },
    { text: "建筑", size: 25 },
    { text: "电动自行车", size: 18 },
    { text: "压力容器", size: 25 },
    { text: "灭火器", size: 14 },
	{ text: "汽车", size: 18 },
    { text: "光伏", size: 25 },
    { text: "不锈钢", size: 14 },
	{ text: "混凝土", size: 18 },
    { text: "生活饮用水卫生标准", size: 25 },
    { text: "钢带", size: 14 },
	{ text: "储能", size: 14 },
	{ text: "电梯", size: 18 },
    { text: "特种设备", size: 25 },
    { text: "防火", size: 14 },
	{ text: "电池", size: 18 },
    { text: "电气", size: 25 },
    { text: "GB50016", size: 14 },
	{ text: "危险化学品", size: 12 },
	{ text: "电缆", size: 18 },
    { text: "烟草", size: 25 },
    { text: "电力", size: 14 },
	{ text: "30871", size: 18 },
    { text: "8939", size: 25 },
    { text: "4706.1", size: 12 },
];

// 初始化词云
function drawWordCloud() {
    const width = 282;
     
    const height = 315;
	
    
	$('#cloudTag').empty();
    // 创建SVG容器
    const svg = d3.select("#cloudTag")
        .append("svg")
        .attr("width", width)
        .attr("height", height);

    // 配置词云布局
    const layout = d3.layout.cloud()
        .size([width, height])
        .words(words.map(d => ({ 
            text: d.text, 
            size: d.size,
            url: d.url 
        })))
        .padding(5)
        .rotate(() => (~~(Math.random() * 2) - 0.5) * 90) // 随机旋转角度
        .font("SimHei")  // 使用中文字体
        .fontSize(d => d.size)
        .on("end", draw);

    layout.start();

    // 绘制函数
    function draw(words) {
        // 隐藏加载动画
        d3.select("#loading").style("display", "none");

        // 绘制词云
        svg.append("g")
	        .attr("transform", 'translate('+(width/2)+','+(height/2)+')')
	        .selectAll("text")
	        .data(words)
	        .enter()
	        .append("a")
	        .attr("xlink:href", function(d){return "std_list?p.p1=0&p.p90=circulation_date&p.p91=desc&p.p2="+encodeURI(d.text)}) 
	        .append("text")
	        .style("font-size", d => d.size+'px')
			.style("cursor", "pointer")
	        .style("font-family", "SimHei") // 确保中文字体生效
	        .style("fill", d => d3.hsl(Math.random() * 360, 0.7, 0.5))
	        .attr("text-anchor", "middle")
	        .attr("transform", d => 'translate('+d.x+','+d.y+')rotate('+d.rotate+')')
	        .text(d => d.text)
	        .on("mouseover", function() {
	            d3.select(this).style("fill", "#ff0000");
	        })
	        .on("mouseout", function(d) {
	            d3.select(this).style("fill", d3.scale.category20()(Math.random() * 20));
	        });
    }
}
$(document).ready(function(){
	$('[data-toggle="tooltip"]').tooltip()
	var config = {
			state	: '现行',
			type	: 'name'
		};
	$('.status ul li').click(function(){
		var el = $(this);
		if(el.attr('tab_id')=='2'){
			if(el.hasClass('spe2')){
				return false;
			}		
			el.siblings().removeClass('spe1');
			el.siblings().removeClass('spe2');
			el.addClass('spe2');
		}else{
			 if(el.hasClass('spe1')){
				return false;
			}		
			el.siblings().removeClass('spe1');
			el.siblings().removeClass('spe2');
			el.addClass('spe1'); 
		}
		
		config.state = el.attr('data-searchType');
	});
	//,#searchICS
	$('#searchCode,#searchName').change(function(){
		config.type = this.value;
	});
	$('#searchName').click();
	$('#searchBtn').click(function(){
		searchS();
	});
	$('#icsSearchBtn').on('click',function(){ 
		window.open('/bzgk/gb/icsMainQuery?icsName='+$('#icsInput').val());   
	});
	$('.icsDiv a').on('click',function(){ 
		window.open('/bzgk/gb/icsMainQuery?icsKey='+$(this).attr('icscode')+'.'+'&icsName='+encodeURI($(this).html())); 
	});
	$('.type-btn').on('click',function(){ 
		$('.type-btn').removeClass('btn-default');
		$('.type-btn:eq(0)').addClass('btn-primary');
		$('.type-btn:eq(1)').addClass('btn-warning');
		$('.type-btn:eq(2)').addClass('btn-info');
		$(this).removeClass('btn-primary btn-warning btn-info').addClass('btn-default');
		$('.type-panel').hide();
	});
	$('#nsBtn').on('click',function(){ 
		$('#nsPanel').show();
	});
	$('#psBtn').on('click',function(){ 
		$('#psPanel').show();
	});
	$('#tsBtn').on('click',function(){ 
		$('#tsPanel').show();
	});
});
function searchA(anouncement){
	var reg=/[\u4E00-\u9FA5]/g;
	var result=anouncement.replace(reg,'');
	if(result.length==5){
		result = result.substring(0,4)+'0'+result.substring(4,5);
	}
	window.open("http://www.sac.gov.cn/gzfw/ggcx/gjbzgg/"+result,"_blank");
}
function searchS(){
	var url="std_list?p.p1=0&p.p90=circulation_date&p.p91=desc&p.p2="+$('#searchInput').val();
	window.open(encodeURI(url));
}
function searchSWithWord(word){
	var url="std_list?p.p1=0&p.p90=circulation_date&p.p91=desc&p.p2="+word;
	window.open(encodeURI(url));
}
